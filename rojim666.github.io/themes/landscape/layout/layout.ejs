    { name: '千棘盔', image: 'images/千棘盔.png' },
    { name: '卡洛儿', image: 'images/卡洛儿.png' },
    { name: '卡瓦重', image: 'images/卡瓦重.png' },
    { name: '卷毛鸭', image: 'images/卷毛鸭.png' },
