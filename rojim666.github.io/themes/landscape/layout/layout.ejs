    { name: '厉毒修萝', image: 'images/厉毒修萝.png' },
    { name: '双灯鱼', image: 'images/双灯鱼.png' },
    { name: '古卷匣魔像', image: 'images/古卷匣魔像.png' },
    { name: '古卷执政官', image: 'images/古卷执政官.png' },
    { name: '古啦多', image: 'images/古啦多.png' },
    { name: '叮叮恶魔', image: 'images/叮叮恶魔.png' },
    { name: '咔咔壳', image: 'images/咔咔壳.png' },
    { name: '咔咔鸟', image: 'images/咔咔鸟.png' },
