        function normalizeSprites(rawSprites) {
            const flattened = Array.isArray(rawSprites) ? rawSprites.flat() : [];
            const seen = new Set();
            return flattened
                .filter(item => item && typeof item === 'object')
                .map(item => ({
                    name: String(item.name || '').trim(),
                    image: String(item.image || '').trim()
                }))
                .filter(item => item.name)
                .filter(item => {
                    if (seen.has(item.name)) return false;
                    seen.add(item.name);
                    return true;
                });
        }

        function getSpriteImagePath(name) {
            return encodeURI(`images/${name}.png`);
        }

        function getSpriteDisplayImage(sprite) {
            return sprite.image || getSpriteImagePath(sprite.name);
        }

        function normalizeTeamNames(team) {
            if (!Array.isArray(team)) return [];
            return team
                .map(name => String(name || '').trim())
                .filter(Boolean);
        }

        const spritePool = normalizeSprites(sprites);

        let history = JSON.parse(localStorage.getItem('drawHistory') || '[]');
        let selectedHistoryIndex = null;
        let userData = JSON.parse(localStorage.getItem('userData') || JSON.stringify({
            name: '训练家',
            level: 1,
            experience: 0,
            totalDraws: 0,
            wins: 0,
            losses: 0
        }));

        // 切换用户菜单
        function toggleUserMenu() {
            const dropdown = document.getElementById('userDropdown');
            dropdown.classList.toggle('show');
        }

        // 点击外部关闭菜单
        document.addEventListener('click', (e) => {
            const userMenu = document.querySelector('.user-menu');
            if (!userMenu.contains(e.target)) {
                document.getElementById('userDropdown').classList.remove('show');
            }
        });

        // 更新用户数据显示
        function updateUserUI() {
            document.getElementById('userName').textContent = userData.name;
            document.getElementById('userLevel').textContent = `Lv.${userData.level} ${getRankName(userData.level)}`;
            document.getElementById('totalDraws').textContent = userData.totalDraws;
            
            const total = userData.wins + userData.losses;
            const winRate = total > 0 ? Math.round((userData.wins / total) * 100) : 0;
            document.getElementById('winRate').textContent = `${winRate}%`;
        }

        // 获取等级称号
        function getRankName(level) {
            if (level < 5) return '新手训练家';
            if (level < 10) return '初级训练家';
            if (level < 20) return '中级训练家';
            if (level < 30) return '高级训练家';
            if (level < 50) return '精英训练家';
            if (level < 70) return '王国守护者';
            if (level < 90) return '传奇训练家';
            return '洛克王国';
        }

        // 编辑资料
        function editProfile() {
            const newName = prompt('请输入你的新昵称：', userData.name);
            if (newName && newName.trim()) {
                userData.name = newName.trim();
                saveUserData();
                updateUserUI();
                alert('昵称修改成功！');
            }
        }

        // 导出数据
        function exportData() {
            const data = {
                userData,
                history
            };
            const blob = new Blob([JSON.stringify(data, null, 2)], { type: 'application/json' });
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = `洛克配队数据_${new Date().toLocaleDateString()}.json`;
            a.click();
            URL.revokeObjectURL(url);
        }

        // 导入数据
        function importData() {
            const input = document.createElement('input');
            input.type = 'file';
            input.accept = '.json';
            input.onchange = (e) => {
                const file = e.target.files[0];
                if (!file) return;
                
                const reader = new FileReader();
                reader.onload = (event) => {
                    try {
                        const data = JSON.parse(event.target.result);
                        if (data.userData && data.history) {
                            if (confirm('确定要导入数据吗？现有数据将会被覆盖！')) {
                                userData = data.userData;
                                history = data.history;
                                saveUserData();
                                saveHistory();
                                updateUserUI();
                                renderHistory();
                                alert('数据导入成功！');
                            }
                        } else {
                            alert('无效的数据文件！');
                        }
                    } catch (e) {
                        alert('文件解析失败！');
                    }
                };
                reader.readAsText(file);
            };
            input.click();
        }

        // 重置数据
        function resetData() {
            if (confirm('确定要重置所有数据吗？历史记录和用户信息都会被清空，无法恢复！')) {
                userData = {
                    name: '训练家',
                    level: 1,
                    experience: 0,
                    totalDraws: 0,
                    wins: 0,
                    losses: 0
                };
                history = [];
                saveUserData();
                saveHistory();
                updateUserUI();
                renderHistory();
                document.getElementById('teamContainer').innerHTML = `
                    <div class="empty-state">
                        <p>点击下方按钮开始抽签~</p>
                    </div>
                `;
                alert('数据已重置！');
            }
        }

        // 退出登录（重置数据）
        function logout() {
            if (confirm('确定要退出登录吗？所有本地数据都会被清空！')) {
                localStorage.removeItem('userData');
                localStorage.removeItem('drawHistory');
                location.reload();
            }
        }

        // 保存用户数据
        function saveUserData() {
            localStorage.setItem('userData', JSON.stringify(userData));
        }

        // 保存历史
        function saveHistory() {
            localStorage.setItem('drawHistory', JSON.stringify(history));
        }

        // 增加经验
        function addExperience(exp) {
            userData.experience += exp;
            const requiredExp = userData.level * 100;
            if (userData.experience >= requiredExp) {
                userData.experience -= requiredExp;
                userData.level += 1;
                alert(`恭喜升级！现在是 Lv.${userData.level} ${getRankName(userData.level)}！`);
            }
            saveUserData();
        }

        // 渲染历史
        function renderHistory() {
            const historyList = document.getElementById('historyList');
            
            if (!Array.isArray(history) || history.length === 0) {
                selectedHistoryIndex = null;
                historyList.innerHTML = '<div class="empty-state" id="emptyHistory">还没有抽签记录</div>';
                return;
            }

            if (selectedHistoryIndex !== null && (selectedHistoryIndex < 0 || selectedHistoryIndex >= history.length)) {
                selectedHistoryIndex = null;
            }

            historyList.innerHTML = history.map((item, index) => `
                <div class="history-item ${selectedHistoryIndex === index ? 'selected' : ''}" data-history-index="${index}">
                    <div class="history-time">${item?.time || '未知时间'}</div>
                    <div class="history-sprites">
                        ${normalizeTeamNames(item?.team).map(sprite => `<div class="history-sprite">${sprite || '未知精灵'}</div>`).join('') || '<div class="history-sprite">未知精灵</div>'}
                    </div>
                </div>
            `).join('');
        }

        function renderTeamFromNames(teamNames) {
            const container = document.getElementById('teamContainer');
            const names = normalizeTeamNames(teamNames).slice(0, 6);

            if (names.length === 0) {
                container.innerHTML = '<div class="empty-state"><p>点击下方按钮开始抽签</p></div>';
                return;
            }

            container.innerHTML = '';
            names.forEach((name, i) => {
                const matched = spritePool.find(s => s.name === name) || { name, image: '' };
                const spriteImage = getSpriteDisplayImage(matched);
                const card = document.createElement('div');
                card.className = 'sprite-card';
                card.style.animationDelay = `${i * 0.06}s`;
                card.innerHTML = `
                    <div class="sprite-image">
                        <img src="${spriteImage}" alt="${matched.name}" loading="lazy" decoding="async" onerror="this.replaceWith(createSpriteFallbackSvg())">
                    </div>
                    <div class="sprite-name">${matched.name}</div>
                    <div class="sprite-index">第 ${i + 1} 位</div>
                `;
                container.appendChild(card);
            });
        }

        function selectHistory(index) {
            if (!Array.isArray(history) || index < 0 || index >= history.length) return;
            selectedHistoryIndex = index;
            renderHistory();
            renderTeamFromNames(history[index]?.team || []);
        }

        function sleep(ms) {
            return new Promise(resolve => setTimeout(resolve, ms));
        }

        function createRollingCard(index) {
            const card = document.createElement('div');
            card.className = 'sprite-card sprite-card--rolling';
            card.innerHTML = `
                <div class="sprite-image">${createSpriteFallbackSvg().outerHTML}</div>
                <div class="sprite-name">载入中</div>
                <div class="sprite-index">准备第 ${index + 1} 位</div>
            `;
            return card;
        }

        function revealSpriteCard(card, sprite, index) {
            const spriteImage = getSpriteDisplayImage(sprite);
            card.classList.remove('sprite-card--rolling');
            card.style.animation = 'none';
            card.innerHTML = `
                <div class="sprite-image">
                    <img src="${spriteImage}" alt="${sprite.name}" loading="lazy" decoding="async" onerror="this.replaceWith(createSpriteFallbackSvg())">
                </div>
                <div class="sprite-name">${sprite.name}</div>
                <div class="sprite-index">第 ${index + 1} 位</div>
            `;
            card.offsetHeight;
            card.style.animation = `fadeIn 0.35s ease forwards`;
        }

        // 抽签
        async function drawTeam() {
            const btn = document.getElementById('drawBtn');
            const container = document.getElementById('teamContainer');
            
            if (spritePool.length === 0) {
                alert('没有找到精灵数据哦');
                return;
            }

            if (spritePool.length < 6) {
                alert('精灵数据不足 6 个，无法完成抽签');
                return;
            }

            btn.disabled = true;
            btn.innerHTML = `<span class="ui-icon button-icon" aria-hidden="true">${iconSvg('draw')}</span><span>抽签中...</span>`;
            container.innerHTML = '';

            const rollingCards = [];
            for (let i = 0; i < 6; i++) {
                const rollingCard = createRollingCard(i);
                rollingCards.push(rollingCard);
                container.appendChild(rollingCard);
            }

            // 随机选6个不重复的精灵
            const selected = [];
            const temp = [...spritePool];
            for (let i = 0; i < 6 && temp.length > 0; i++) {
                const randomIndex = Math.floor(Math.random() * temp.length);
                selected.push(temp[randomIndex]);
                temp.splice(randomIndex, 1);
            }

            const rollingTimer = setInterval(() => {
                rollingCards.forEach((card, i) => {
                    const randomName = spritePool[Math.floor(Math.random() * spritePool.length)]?.name || '载入中';
                    const nameEl = card.querySelector('.sprite-name');
                    const idxEl = card.querySelector('.sprite-index');
                    if (nameEl) nameEl.textContent = randomName;
                    if (idxEl) idxEl.textContent = `滚动第 ${i + 1} 位`;
                });
            }, 70);

            await sleep(520);
            clearInterval(rollingTimer);

            for (let i = 0; i < selected.length; i++) {
                revealSpriteCard(rollingCards[i], selected[i], i);
                await sleep(120);
            }

            // 恢复按钮
            btn.disabled = false;
            btn.innerHTML = `<span class="ui-icon button-icon" aria-hidden="true">${iconSvg('draw')}</span><span>再抽一次</span>`;

            // 更新用户数据
            userData.totalDraws += 1;
            addExperience(10); // 每次抽签加10经验
            saveUserData();
            updateUserUI();

            // 保存到历史
            const now = new Date();
            const timeStr = `${now.getMonth()+1}/${now.getDate()} ${now.getHours().toString().padStart(2, '0')}:${now.getMinutes().toString().padStart(2, '0')}`;
            history.unshift({
                time: timeStr,
                team: selected.map(s => s?.name || '未知精灵')
            });

            // 最多保留20条历史
            if (history.length > 20) {
                history = history.slice(0, 20);
            }

            saveHistory();
            renderHistory();

            btn.disabled = false;
            btn.innerHTML = `<span class="ui-icon button-icon" aria-hidden="true">${iconSvg('draw')}</span><span>再抽一次</span>`;
        }

        // 清空历史
        function clearHistory() {
            if (confirm('确定要清空所有抽签历史吗？')) {
                history = [];
                selectedHistoryIndex = null;
                localStorage.removeItem('drawHistory');
                renderHistory();
            }
        }

        // 初始化
        updateUserUI();
        renderHistory();

        document.getElementById('historyList').addEventListener('click', (e) => {
            const item = e.target.closest('.history-item');
            if (!item) return;
            const idx = Number(item.dataset.historyIndex);
            if (Number.isNaN(idx)) return;
            selectHistory(idx);
        });

        function createSpriteFallbackSvg() {
            const wrapper = document.createElement('div');
            wrapper.innerHTML = `
                <svg viewBox="0 0 64 64" width="48" height="48" aria-hidden="true" focusable="false">
                    <rect x="10" y="8" width="44" height="48" rx="10" fill="#e9ecef"></rect>
                    <path d="M22 40c4-6 16-6 20 0" fill="none" stroke="#9aa3af" stroke-width="3" stroke-linecap="round"></path>
                    <circle cx="26" cy="26" r="7" fill="#9aa3af"></circle>
                </svg>
            `;
            return wrapper.firstElementChild;
        }

        function iconSvg(name) {
            const icons = {
