        function normalizeSprites(rawSprites) {
            const flattened = Array.isArray(rawSprites) ? rawSprites.flat() : [];
            const seen = new Set();
            return flattened
                .filter(item => item && typeof item === 'object')
                .map(item => ({
                    name: String(item.name || '').trim(),
                    image: String(item.image || '').trim()
                }))
                .filter(item => item.name)
                .filter(item => {
                    if (seen.has(item.name)) return false;
                    seen.add(item.name);
                    return true;
                });
        }

        function getSpriteImagePath(name) {
            return encodeURI(`images/${name}.png`);
        }

        function getSpriteDisplayImage(sprite) {
            return sprite.image || getSpriteImagePath(sprite.name);
        }

        function normalizeTeamNames(team) {
            if (!Array.isArray(team)) return [];
            return team
                .map(name => String(name || '').trim())
                .filter(Boolean);
        }

        const spritePool = normalizeSprites(sprites);

        let history = JSON.parse(localStorage.getItem('drawHistory') || '[]');
        let userData = JSON.parse(localStorage.getItem('userData') || JSON.stringify({
            name: '训练家',
            level: 1,
            experience: 0,
            totalDraws: 0,
            wins: 0,
            losses: 0
        }));

        // 切换用户菜单
        function toggleUserMenu() {
            const dropdown = document.getElementById('userDropdown');
            dropdown.classList.toggle('show');
        }

        // 点击外部关闭菜单
        document.addEventListener('click', (e) => {
            const userMenu = document.querySelector('.user-menu');
            if (!userMenu.contains(e.target)) {
                document.getElementById('userDropdown').classList.remove('show');
            }
        });

        // 更新用户数据显示
        function updateUserUI() {
            document.getElementById('userName').textContent = userData.name;
            document.getElementById('userLevel').textContent = `Lv.${userData.level} ${getRankName(userData.level)}`;
            document.getElementById('totalDraws').textContent = userData.totalDraws;
            
            const total = userData.wins + userData.losses;
            const winRate = total > 0 ? Math.round((userData.wins / total) * 100) : 0;
            document.getElementById('winRate').textContent = `${winRate}%`;
        }

        // 获取等级称号
        function getRankName(level) {
            if (level < 5) return '新手训练家';
            if (level < 10) return '初级训练家';
            if (level < 20) return '中级训练家';
            if (level < 30) return '高级训练家';
            if (level < 50) return '精英训练家';
            if (level < 70) return '王国守护者';
            if (level < 90) return '传奇训练家';
            return '洛克王国';
        }

        // 编辑资料
        function editProfile() {
            const newName = prompt('请输入你的新昵称：', userData.name);
            if (newName && newName.trim()) {
                userData.name = newName.trim();
                saveUserData();
                updateUserUI();
                alert('昵称修改成功！');
            }
        }

        // 导出数据
        function exportData() {
            const data = {
                userData,
                history
            };
            const blob = new Blob([JSON.stringify(data, null, 2)], { type: 'application/json' });
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = `洛克配队数据_${new Date().toLocaleDateString()}.json`;
            a.click();
            URL.revokeObjectURL(url);
        }

        // 导入数据
        function importData() {
            const input = document.createElement('input');
            input.type = 'file';
            input.accept = '.json';
            input.onchange = (e) => {
                const file = e.target.files[0];
                if (!file) return;
                
                const reader = new FileReader();
                reader.onload = (event) => {
                    try {
                        const data = JSON.parse(event.target.result);
                        if (data.userData && data.history) {
                            if (confirm('确定要导入数据吗？现有数据将会被覆盖！')) {
                                userData = data.userData;
                                history = data.history;
                                saveUserData();
                                saveHistory();
                                updateUserUI();
                                renderHistory();
                                alert('数据导入成功！');
                            }
                        } else {
                            alert('无效的数据文件！');
                        }
                    } catch (e) {
                        alert('文件解析失败！');
                    }
                };
                reader.readAsText(file);
            };
            input.click();
        }

        // 重置数据
        function resetData() {
            if (confirm('确定要重置所有数据吗？历史记录和用户信息都会被清空，无法恢复！')) {
                userData = {
                    name: '训练家',
                    level: 1,
                    experience: 0,
                    totalDraws: 0,
                    wins: 0,
                    losses: 0
                };
                history = [];
                saveUserData();
                saveHistory();
                updateUserUI();
                renderHistory();
                document.getElementById('teamContainer').innerHTML = `
                    <div class="empty-state">
                        <p>点击下方按钮开始抽签~</p>
                    </div>
                `;
                alert('数据已重置！');
            }
        }

        // 退出登录（重置数据）
        function logout() {
            if (confirm('确定要退出登录吗？所有本地数据都会被清空！')) {
                localStorage.removeItem('userData');
                localStorage.removeItem('drawHistory');
                location.reload();
            }
        }

        // 保存用户数据
        function saveUserData() {
            localStorage.setItem('userData', JSON.stringify(userData));
        }

        // 保存历史
        function saveHistory() {
            localStorage.setItem('drawHistory', JSON.stringify(history));
        }

        // 增加经验
        function addExperience(exp) {
            userData.experience += exp;
            const requiredExp = userData.level * 100;
            if (userData.experience >= requiredExp) {
                userData.experience -= requiredExp;
                userData.level += 1;
                alert(`恭喜升级！现在是 Lv.${userData.level} ${getRankName(userData.level)}！`);
            }
            saveUserData();
        }

        // 渲染历史
        function renderHistory() {
            const historyList = document.getElementById('historyList');
            const emptyHistory = document.getElementById('emptyHistory');
            
            if (!Array.isArray(history) || history.length === 0) {
                emptyHistory.style.display = 'block';
                historyList.innerHTML = '';
                historyList.appendChild(emptyHistory);
                return;
            }

            emptyHistory.style.display = 'none';
            historyList.innerHTML = history.map((item, index) => `
                <div class="history-item">
                    <div class="history-time">${item?.time || '未知时间'}</div>
                    <div class="history-sprites">
                        ${normalizeTeamNames(item?.team).map(sprite => `<div class="history-sprite">${sprite || '未知精灵'}</div>`).join('') || '<div class="history-sprite">未知精灵</div>'}
                    </div>
                </div>
            `).join('');
        }

        // 抽签
        function drawTeam() {
            const btn = document.getElementById('drawBtn');
            const container = document.getElementById('teamContainer');
            
            if (spritePool.length === 0) {
                alert('没有找到精灵数据哦');
                return;
            }

            if (spritePool.length < 6) {
                alert('精灵数据不足 6 个，无法完成抽签');
                return;
            }

            btn.disabled = true;
            btn.innerHTML = `<span class="ui-icon button-icon" aria-hidden="true">${iconSvg('draw')}</span><span>抽签中...</span>`;
            container.innerHTML = '';

            // 随机选6个不重复的精灵
            const selected = [];
            const temp = [...spritePool];
            for (let i = 0; i < 6 && temp.length > 0; i++) {
                const randomIndex = Math.floor(Math.random() * temp.length);
                selected.push(temp[randomIndex]);
                temp.splice(randomIndex, 1);
            }

            // 直接显示所有精灵
            selected.forEach((sprite, i) => {
                const card = document.createElement('div');
                card.className = 'sprite-card';
                card.style.animationDelay = `${i * 0.1}s`;
                const spriteImage = getSpriteDisplayImage(sprite);
                
                card.innerHTML = `
                    <div class="sprite-image">
                        <img src="${spriteImage}" alt="${sprite.name}" onerror="this.replaceWith(createSpriteFallbackSvg())">
                    </div>
                    <div class="sprite-name">${sprite.name}</div>
                    <div class="sprite-index">第 ${i+1} 位</div>
                `;
                
                container.appendChild(card);
            });

            // 恢复按钮
            btn.disabled = false;
            btn.innerHTML = `<span class="ui-icon button-icon" aria-hidden="true">${iconSvg('draw')}</span><span>再抽一次</span>`;

            // 更新用户数据
            userData.totalDraws += 1;
            addExperience(10); // 每次抽签加10经验
            saveUserData();
            updateUserUI();

            // 保存到历史
            const now = new Date();
            const timeStr = `${now.getMonth()+1}/${now.getDate()} ${now.getHours().toString().padStart(2, '0')}:${now.getMinutes().toString().padStart(2, '0')}`;
            history.unshift({
                time: timeStr,
                team: selected.map(s => s?.name || '未知精灵')
            });

            // 最多保留20条历史
            if (history.length > 20) {
                history = history.slice(0, 20);
            }

            saveHistory();
            renderHistory();

            btn.disabled = false;
            btn.innerHTML = `<span class="ui-icon button-icon" aria-hidden="true">${iconSvg('draw')}</span><span>再抽一次</span>`;
        }

        // 清空历史
        function clearHistory() {
            if (confirm('确定要清空所有抽签历史吗？')) {
                history = [];
                localStorage.removeItem('drawHistory');
                renderHistory();
            }
        }

        // 初始化
        updateUserUI();
        renderHistory();

        function createSpriteFallbackSvg() {
            const wrapper = document.createElement('div');
            wrapper.innerHTML = `
                <svg viewBox="0 0 64 64" width="48" height="48" aria-hidden="true" focusable="false">
                    <rect x="10" y="8" width="44" height="48" rx="10" fill="#e9ecef"></rect>
                    <path d="M22 40c4-6 16-6 20 0" fill="none" stroke="#9aa3af" stroke-width="3" stroke-linecap="round"></path>
                    <circle cx="26" cy="26" r="7" fill="#9aa3af"></circle>
                </svg>
            `;
            return wrapper.firstElementChild;
        }

        function iconSvg(name) {
            const icons = {
                user: '<svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="8" r="4" fill="currentColor"></circle><path d="M4 20c1.8-4.5 14.2-4.5 16 0" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"></path></svg>',
                gamepad: '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M7 9h10a5 5 0 0 1 5 5v1.5a3.5 3.5 0 0 1-6.8 1.1l-.5-1.6H9.3l-.5 1.6A3.5 3.5 0 0 1 2 15.5V14a5 5 0 0 1 5-5Z" fill="currentColor"></path><path d="M8 12v3M6.5 13.5h3M16 11h0M18 13h0" stroke="#fff" stroke-width="1.8" stroke-linecap="round"></path></svg>',
                edit: '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 17.8V20h2.2l10.7-10.7-2.2-2.2L4 17.8Zm15.7-9.5a1 1 0 0 0 0-1.4l-2.6-2.6a1 1 0 0 0-1.4 0l-1.4 1.4 4 4 1.4-1.4Z" fill="currentColor"></path></svg>',
                export: '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 3v9m0-9 4 4m-4-4-4 4" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path><path d="M5 14v5h14v-5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"></path></svg>',
                import: '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 21V12m0 9-4-4m4 4 4-4" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path><path d="M5 10V5h14v5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"></path></svg>',
                reset: '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M6 12a6 6 0 1 1 2 4.5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"></path><path d="M6 12H3m3 0-2-2m2 2-2 2" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path></svg>',
                logout: '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M10 7V5h9v14h-9v-2" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path><path d="M13 12H4m0 0 3-3m-3 3 3 3" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path></svg>',
                draw: '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 5h5l2 3h9v11H4V5Z" fill="none" stroke="currentColor" stroke-width="2" stroke-linejoin="round"></path><path d="M8 12l2 2 4-4" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path></svg>',
                history: '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 7v5l3 2" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path><path d="M20 12a8 8 0 1 1-2.4-5.7" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"></path></svg>'
            };
            return icons[name] || '';
        }

        document.getElementById('userAvatar').innerHTML = `<span class="ui-icon" aria-hidden="true">${iconSvg('user')}</span>`;
        document.querySelector('.user-avatar-large').innerHTML = `<span class="ui-icon" aria-hidden="true">${iconSvg('gamepad')}</span>`;
        document.querySelector('.menu-list .menu-item[onclick="editProfile()"]').innerHTML = `<span class="ui-icon menu-icon" aria-hidden="true">${iconSvg('edit')}</span><span>编辑资料</span>`;
        document.querySelector('.menu-list .menu-item[onclick="exportData()"]').innerHTML = `<span class="ui-icon menu-icon" aria-hidden="true">${iconSvg('export')}</span><span>导出数据</span>`;
        document.querySelector('.menu-list .menu-item[onclick="importData()"]').innerHTML = `<span class="ui-icon menu-icon" aria-hidden="true">${iconSvg('import')}</span><span>导入数据</span>`;
        document.querySelector('.menu-list .menu-item[onclick="resetData()"]').innerHTML = `<span class="ui-icon menu-icon" aria-hidden="true">${iconSvg('reset')}</span><span>重置所有数据</span>`;
        document.querySelector('.menu-list .menu-item.logout').innerHTML = `<span class="ui-icon menu-icon" aria-hidden="true">${iconSvg('logout')}</span><span>退出登录</span>`;
        document.querySelector('.header-content h1').innerHTML = `<img class="title-logo" src="images/logo_rocom.png" alt="洛克王国"><span class="title-text">随机配队抽签</span>`;
        document.querySelector('.draw-btn').innerHTML = `<span class="ui-icon button-icon" aria-hidden="true">${iconSvg('draw')}</span><span>开始抽签</span>`;
        document.querySelector('.history-title span').innerHTML = `<span class="ui-icon history-icon" aria-hidden="true">${iconSvg('history')}</span>抽签历史`;
    </script>
</body>
</html>